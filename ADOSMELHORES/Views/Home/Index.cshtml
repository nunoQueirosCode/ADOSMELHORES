@{
    ViewData["Title"] = "Dashboard Geral";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="color: var(--azul-conhecimento); font-weight: 700; margin-bottom: 0;">Visão Geral</h2>
        <span class="text-muted">Resumo de Ativos e Recursos Humanos da ADOSMELHORES</span>
    </div>
    <div class="text-end">
        <span class="text-muted small d-block">Data do Sistema</span>
        <strong style="color: var(--ciano-evolucao);">@DateTime.Now.ToString("dd 'de' MMMM, yyyy")</strong>
    </div>
</div>

<div class="row g-4 mb-4">
    
    <div class="col-xl-3 col-md-6">
        <div class="card card-ados h-100" style="border-left: 4px solid var(--azul-conhecimento);">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Total Funcionários</p>
                        <h2 class="mb-0 fw-bold" style="color: var(--azul-conhecimento);">124</h2>
                    </div>
                    <div class="bg-light rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; color: var(--azul-conhecimento); font-size: 1.5rem;">
                        <i class="fa-solid fa-users"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted small">
                    <span class="text-success"><i class="fa-solid fa-arrow-trend-up me-1"></i>+3</span> desde o mês passado
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card card-ados h-100" style="border-left: 4px solid var(--ciano-evolucao);">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Despesa Salarial</p>
                        <h2 class="mb-0 fw-bold" style="color: var(--azul-conhecimento);">42K €</h2>
                    </div>
                    <div class="bg-light rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; color: var(--ciano-evolucao); font-size: 1.5rem;">
                        <i class="fa-solid fa-euro-sign"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted small">
                    Baseado nos contratos e formadores ativos
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card card-ados h-100" style="border-left: 4px solid var(--dourado-excelencia);">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Contratos a Expirar</p>
                        <h2 class="mb-0 fw-bold text-warning">8</h2>
                    </div>
                    <div class="bg-warning bg-opacity-10 rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; color: var(--dourado-excelencia); font-size: 1.5rem;">
                        <i class="fa-solid fa-file-contract"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted small">
                    <span class="text-warning"><i class="fa-solid fa-clock me-1"></i></span> Nos próximos 30 dias
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card card-ados h-100" style="border-left: 4px solid #ef4444;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Reg. Criminais Expirados</p>
                        <h2 class="mb-0 fw-bold text-danger">3</h2>
                    </div>
                    <div class="bg-danger bg-opacity-10 rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; color: #ef4444; font-size: 1.5rem;">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted small">
                    <a href="#" class="text-danger fw-bold text-decoration-none">Ver lista completa <i class="fa-solid fa-arrow-right ms-1"></i></a>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="row g-4 mb-4">
    
    <div class="col-lg-5">
        <div class="card card-ados h-100">
            <div class="card-header card-ados-header bg-white">
                <i class="fa-solid fa-chart-pie me-2"></i>Distribuição por Cargo
            </div>
            <div class="card-body d-flex justify-content-center align-items-center">
                <canvas id="graficoCargos" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card card-ados h-100">
            <div class="card-header card-ados-header bg-white d-flex justify-content-between align-items-center">
                <span><i class="fa-solid fa-bell me-2"></i>Avisos Pendentes</span>
                <button class="btn btn-sm btn-light border">Ver Todos</button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4">Funcionário</th>
                                <th>Tipo de Aviso</th>
                                <th>Data Limite</th>
                                <th class="text-end pe-4">Ação</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="ps-4 fw-bold">Carlos Pereira</td>
                                <td><span class="badge bg-danger bg-opacity-10 text-danger border border-danger">Reg. Criminal Expirado</span></td>
                                <td class="text-danger fw-bold">10/05/2026</td>
                                <td class="text-end pe-4">
                                    <a href="#" class="btn btn-sm btn-light text-info"><i class="fa-solid fa-eye"></i></a>
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4 fw-bold">Ana Silva</td>
                                <td><span class="badge bg-warning bg-opacity-10 text-warning border border-warning">Fim de Contrato</span></td>
                                <td class="text-warning">25/05/2026</td>
                                <td class="text-end pe-4">
                                    <a href="#" class="btn btn-sm btn-light text-info"><i class="fa-solid fa-eye"></i></a>
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4 fw-bold">João Marques</td>
                                <td><span class="badge bg-danger bg-opacity-10 text-danger border border-danger">Reg. Criminal Expirado</span></td>
                                <td class="text-danger fw-bold">12/04/2026</td>
                                <td class="text-end pe-4">
                                    <a href="#" class="btn btn-sm btn-light text-info"><i class="fa-solid fa-eye"></i></a>
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4 fw-bold">Marta Sousa</td>
                                <td><span class="badge bg-primary bg-opacity-10 text-primary border border-primary">Falta Assinatura Ativo</span></td>
                                <td class="text-muted">A aguardar</td>
                                <td class="text-end pe-4">
                                    <a href="#" class="btn btn-sm btn-light text-info"><i class="fa-solid fa-eye"></i></a>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="row g-4">
    <div class="col-12">
        <div class="card border-0 bg-transparent">
            <div class="d-flex gap-3">
                <a asp-controller="Funcionarios" asp-action="Create" class="btn btn-ados py-2 px-4 shadow-sm">
                    <i class="fa-solid fa-user-plus me-2"></i>Novo Funcionário
                </a>
                <button class="btn btn-ados-outline py-2 px-4 shadow-sm bg-white">
                    <i class="fa-solid fa-laptop-medical me-2"></i>Registar Ativo
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        $(document).ready(function () {
            // Contexto do Canvas no HTML
            var ctx = document.getElementById('graficoCargos').getContext('2d');

            // Dados estáticos para o gráfico (Mais tarde podes injetar os valores do C# aqui)
            var dadosCargos = {
                labels: ['Formadores', 'Secretariado', 'Coordenadores', 'Diretores'],
                datasets: [{
                    data: [85, 20, 15, 4], // Os teus números estáticos
                    backgroundColor: [
                        '#06B6D4', // Ciano Evolução (Maioria Formadores)
                        '#F59E0B', // Dourado Excelência
                        '#1A365D', // Azul Conhecimento
                        '#334155'  // Cinza Ardósia
                    ],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            };

            // Criar o Gráfico Donut
            new Chart(ctx, {
                type: 'doughnut',
                data: dadosCargos,
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%', // Faz o buraco do donut maior
                    plugins: {
                        legend: {
                            position: 'right', // Coloca a legenda à direita
                            labels: {
                                usePointStyle: true,
                                padding: 20,
                                font: {
                                    family: "'Segoe UI', Roboto, sans-serif",
                                    size: 13
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}