@{
    var dataSistemaStr = Context.Request.Cookies["DataSistema"];
    DateTime dataReferencia = DateTime.TryParse(dataSistemaStr, out DateTime dt) ? dt : DateTime.Today;
    string dataCookie = dataReferencia.ToString("dd 'de' MMMM 'de' yyyy");
}

<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ADOSMELHORES Gestão</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- O teu CSS Customizado -->
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
    
    <!-- FontAwesome para os ícones -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    @await RenderSectionAsync("Styles", required: false) <!-- Necessário para conseguir ter CSS dentro das VIEWS -->
</head>
<body>
    @{
        // Descobre em que Controller e Action estamos atualmente
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <div class="wrapper">
        
        <!-- MENU LATERAL (SIDEBAR) -->
        <nav class="sidebar">
            <div class="sidebar-header">
                <!-- Logotipo em Texto -->
                <a class="sidebar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/assets/images/logo.png" width="100%" />
                </a>
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a class="sidebar-link @(currentController == "Home" ? "active" : "") " asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-chart-pie"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a class="sidebar-link @(currentController == "Funcionarios" ? "active" : "") " asp-area="" asp-controller="Funcionarios" asp-action="Index">
                        <i class="fa-solid fa-users"></i> Funcionários
                    </a>
                </li>
                <li>
                    <a class="sidebar-link" asp-area="" asp-controller="Alocacao" asp-action="Index">
                        <i class="fa-solid fa-graduation-cap"></i> Formações
                    </a>
                </li>
                <li>
                    <a class="sidebar-link" asp-area="" asp-controller="Relatorios" asp-action="Index">
                        <i class="fa-solid fa-file-invoice"></i> Relatórios
                    </a>
                </li>
                <li>
                    <a class="sidebar-link" asp-area="" asp-controller="Configuracoes" asp-action="Index">
                        <i class="fa-solid fa-gear"></i> Configurações
                    </a>
                </li>
            </ul>
        </nav>

        <!-- PAINEL PRINCIPAL (LADO DIREITO) -->
        <div class="main-panel">
            
            <!-- CABEÇALHO DO TOPO -->
            <header class="top-header">
                <div class="text-end me-3">
                    <span class="text-muted small text-uppercase fw-bold" style="font-size: 0.75rem;">Data do Sistema</span>
                    <div class="d-flex align-items-center justify-content-end">
                        <span class="fw-bold fs-6 me-2">@dataCookie</span>
        
                        <button class="btn btn-sm btn-warning rounded-circle"
                                style="width: 28px; height: 28px; padding: 0; line-height: 1;"
                                data-bs-toggle="modal"
                                data-bs-target="#modalAlterarDataSistema"
                                title="Alterar Data do Sistema">
                            <i class="fa-solid fa-pencil" style="font-size: 0.75rem;"></i>
                        </button>
                    </div>
                </div>
            </header>

            <!-- CONTEÚDO DAS VIEWS (RenderBody) -->
            <main role="main" class="content-area">
                @RenderBody()
            </main>

            <div class="modal fade" id="modalAlterarDataSistema" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-sm">
                    <div class="modal-content border-0 shadow-lg">
            
                        <form asp-controller="Home" asp-action="DefinirDataSistema" method="post">
                            <div class="modal-header bg-warning border-0">
                                <h6 class="modal-title fw-bold text-dark">
                                    <i class="fa-solid fa-clock-rotate-left me-2"></i>Alterar Data
                                </h6>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                
                            <div class="modal-body p-4">
                                <div class="mb-3">
                                    <label for="novaDataSistema" class="form-label fw-bold small">Nova Data Simulada:</label>
                                    <input type="date" class="form-control" id="novaDataSistema" name="novaDataSistema"
                                           value="@(dataReferencia.ToString("yyyy-MM-dd"))" required>
                                </div>
                    
                                <div class="mt-3 p-3 bg-light rounded text-center border">
                                    <p class="small text-muted mb-2">Pretende voltar à data real do sistema?</p>
                                    <a asp-controller="Home" asp-action="ResetData" class="btn btn-sm btn-outline-primary w-100">
                                        <i class="fa-solid fa-calendar-day me-2"></i>Repor Data de Hoje
                                    </a>
                                </div>
                            </div>
                
                            <div class="modal-footer border-0 bg-light p-2 justify-content-between">
                                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                                <button type="submit" class="btn btn-sm btn-warning fw-bold px-3">Aplicar</button>
                            </div>
                        </form>

                    </div>
                </div>
            </div>

            <!-- RODAPÉ -->
            <footer class="text-muted text-center py-3 mt-auto" style="border-top: 1px solid #e2e8f0;">
                <div class="container-fluid">
                    <small>&copy; @DateTime.Now.Year - ADOSMELHORES Plataforma de Gestão</small>
                </div>
            </footer>
        </div>
        
    </div> <!-- Fim Wrapper -->
    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>