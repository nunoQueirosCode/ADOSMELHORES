
@{
    ViewData["Title"] = "Detalhes do Funcionário";
    
    // Simulação de lógica: O aviso aparece se faltarem menos de 30 dias para expirar
    // (Na tua BD, garante que tens um campo tipo 'DataFimRegistoCriminal')
    bool registoAExpirar = true; // Forçado a true para veres o design. Usa a tua lógica real aqui.
    // Exemplo real: bool registoAExpirar = Model.DataFimRegistoCriminal <= DateTime.Now.AddDays(30);
}

<!-- Cabeçalho com Botão de Voltar -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="color: var(--azul-conhecimento); font-weight: 700; margin-bottom: 0;">Detalhes do Funcionário</h2>
        <span class="text-muted">Informação completa e gestão de documentação</span>
    </div>
    <a asp-action="Index" class="btn btn-light border">
        <i class="fa-solid fa-arrow-left me-2"></i>Voltar à Lista
    </a>
</div>

<!-- SECÇÃO DE ALERTAS / AVISOS -->
@if (registoAExpirar)
{
    <div class="alert alert-warning d-flex align-items-center shadow-sm mb-4" role="alert" style="border-left: 5px solid #ffc107;">
        <i class="fa-solid fa-triangle-exclamation fs-3 me-3 text-warning"></i>
        <div class="flex-grow-1">
            <h5 class="alert-heading mb-1 fw-bold">Atenção: Registo Criminal a Expirar!</h5>
            <p class="mb-0">O registo criminal deste funcionário expira em breve (ou já expirou). É necessário atualizar este documento legal para manter as funções ativas.</p>
        </div>
        <!-- Botão que abre o Modal -->
        <button type="button" class="btn btn-warning fw-bold ms-3" data-bs-toggle="modal" data-bs-target="#modalRegistoCriminal">
            <i class="fa-solid fa-calendar-check me-2"></i>Atualizar Data
        </button>
    </div>
}

<!-- DETALHES DO FUNCIONÁRIO (Layout em 2 Colunas) -->
<div class="row">
    <!-- Coluna Esquerda: Info Principal -->
    <div class="col-md-4 mb-4">
        <div class="card card-ados h-100">
            <div class="card-body text-center p-4">
                <div class="bg-light rounded-circle d-flex justify-content-center align-items-center mx-auto mb-3" style="width: 100px; height: 100px; color: var(--azul-conhecimento); font-size: 2rem;">
                    <!-- Podes pôr as iniciais dinâmicas aqui ou a foto de perfil -->
                    <strong>JM</strong>
                </div>
                <h4 class="fw-bold" style="color: var(--azul-conhecimento);">João Marques</h4>
                <p class="text-muted mb-1">Formador Sénior</p>
                
                <hr />
                
                <div class="text-start mt-4">
                    <p class="mb-2"><i class="fa-solid fa-phone me-2" style="color: var(--ciano-evolucao);"></i> <strong>Telefone:</strong><br /> +351 912 345 678</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Coluna Direita: Mais Detalhes e Ações -->
    <div class="col-md-8 mb-4">
        <div class="card card-ados h-100">
            <div class="card-header card-ados-header d-flex justify-content-between align-items-center">
                <span><i class="fa-solid fa-circle-info me-2"></i>Informação Detalhada</span>
                <!-- Botões de Ação Principais -->
                <div>
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-ados btn-sm me-2">
                        <i class="fa-solid fa-pen"></i> Editar
                    </a>
                    <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#modalDelete">
                        <i class="fa-solid fa-trash"></i> Eliminar
                    </button>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <span class="text-muted small text-uppercase fw-bold">Validade de Contrato</span>
                        <p class="mb-0 text-dark">01 de Setembro de 2021</p>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <span class="text-muted small text-uppercase fw-bold">Validade Registo Criminal</span>
                        <!-- Destacar a data se estiver a expirar -->
                        <p class="mb-0 @(registoAExpirar ? "text-danger fw-bold" : "text-dark")">
                            31 de Outubro de 2023
                            @if (registoAExpirar)
                            {
                                <i class="fa-solid fa-circle-exclamation ms-1"></i>
                            }
                        </p>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <span class="text-muted small text-uppercase fw-bold">Morada Completa</span>
                        <p class="mb-0 text-dark">Rua da Formação, Lote 4, 3º Esq, 4800-000 Guimarães</p>
                    </div>
                    
                </div>
                
                <!--DADOS DIRETOR-->
                <hr />
                <div class="row">
                    
                    <div class="col-sm-6 mb-3">
                        <span class="text-muted small text-uppercase fw-bold">Salário Base</span>
                        <p class="mb-0 text-dark">€1 000 </p>
                    </div>

                    <div class="col-sm-6 mb-3">
                        <span class="text-muted small text-uppercase fw-bold">Bónus Base</span>
