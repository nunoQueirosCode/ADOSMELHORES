@section Scripts {
@*@if (Model.TipoFuncionario == "Coordenador")
 {*@

    <script>
        $(document).ready(function () {
            
            // Variável para guardar a linha (tr) que vai ser apagada
            var linhaParaRemover = null;

            // 1. Quando o modal abre, preenchemos os dados E guardamos a linha
            $('#modalRemoverFormador').on('show.bs.modal', function (event) {
                var button = $(event.relatedTarget);
                
                var formadorId = button.data('id');
                var formadorNome = button.data('nome');
                
                var modal = $(this);
                modal.find('#formadorIdModal').val(formadorId);
                modal.find('#nomeFormadorModal').text(formadorNome);

                // O segredo está aqui: procurar o 'tr' (table row) mais próximo do botão que foi clicado
                linhaParaRemover = button.closest('tr');
            });

            // 2. Quando o utilizador clica em "Sim, Remover" no form do modal
            $('#formRemoverFormador').submit(function (e) {
                e.preventDefault(); // Impede o refresh da página

                var formadorId = $('#formadorIdModal').val();
                var coordenadorId = $('#coordenadorIdModal').val();
                
                // Mudar o texto do botão para mostrar que está a processar
                var btnSubmit = $(this).find('button[type="submit"]');
                var textoOriginal = btnSubmit.html();
                btnSubmit.html('<i class="fa-solid fa-spinner fa-spin me-2"></i>A remover...').prop('disabled', true);

                // 3. Fazer o pedido AJAX
                $.ajax({
                    url: '/FuncionariosController/RemoverAssociacaoAPI', // Caminho para o teu método no Controller
                    type: 'POST',
                    data: {
                        formadorId: formadorId,
                        coordenadorId: coordenadorId
                    },
                    success: function (response) {
                        if (response.sucesso) {
                            // Sucesso! Fechar o modal
                            $('#modalRemoverFormador').modal('hide');

                            // Fazer a animação de desaparecer na linha da tabela
                            if (linhaParaRemover) {
                                linhaParaRemover.css('background-color', '#fee2e2'); // Fica vermelho claro por 1 seg
                                linhaParaRemover.fadeOut(600, function () {
                                    $(this).remove(); // Remove mesmo o HTML depois de desaparecer
                                    
                                    // Bónus: Se quiseres atualizar o contador de formadores no topo
                                    var badgeCount = $('.badge.bg-secondary');
                                    var totalAtuais = parseInt(badgeCount.text()) - 1;
                                    badgeCount.text(totalAtuais);
                                });
                            }
                        } else {
                            // Se o servidor devolver erro (ex: formador não existe)
                            alert('Erro: ' + response.mensagem);
                        }
                    },
                    error: function () {
                        alert('Ocorreu um erro ao tentar comunicar com o servidor.');
                    },
                    complete: function () {
                        // Restaura o botão ao estado original
                        btnSubmit.html(textoOriginal).prop('disabled', false);
                    }
                });
            });

        });
    </script>

@*}*@


@*@if (Model.TipoFuncionario == "Formador")
 {*@

    <script>
        $(document).ready(function () {
            
            $('#formCalcularVencimento').submit(function (e) {
                e.preventDefault(); // Impede que a página faça refresh

                // 1. Obter os valores do modal
                var idFormador = $('#calcFormadorId').val();
                var dataInicio = $('#calcDataInicio').val();
                var dataFim = $('#calcDataFim').val();

                // 2. Colocar o botão em estado de "A carregar..." para dar feedback ao utilizador
                var btn = $('#btnCalcular');
                var textoOriginal = btn.html();
                btn.html('<i class="fa-solid fa-spinner fa-spin me-2"></i>A calcular...').prop('disabled', true);

                // 3. Fazer o pedido AJAX ao Controlador
                $.ajax({
                    url: '/Funcionarios/CalcularVencimentoAPI', // O nome do teu método no C#
                    type: 'POST',
                    data: {
                        id: idFormador,
                        dataInicio: dataInicio,
                        dataFim: dataFim
                    },
                    success: function (response) {
                        if (response.sucesso) {
                            // Se correu bem, injetamos os dados no HTML e mostramos a div
                            $('#valorFinalDisplay').text(response.valorTotalFormatado);
                            $('#detalhesCalculoDisplay').text(response.detalhesCalculo);
                            
                            // Animação suave para mostrar o resultado
                            $('#resultadoCalculo').removeClass('d-none').hide().fadeIn();
                        } else {
                            alert('Atenção: ' + response.mensagem);
                        }
                    },
                    error: function () {
                        alert('Ocorreu um erro de comunicação com o servidor.');
                    },
                    complete: function() {
                        // Independentemente de dar erro ou sucesso, restauramos o botão ao normal
                        btn.html(textoOriginal).prop('disabled', false);
                    }
                });
            });

            // Truque de UI: Limpar o modal sempre que ele é fechado, para estar limpo na próxima vez
            $('#modalCalcularVencimento').on('hidden.bs.modal', function () {
                $('#resultadoCalculo').addClass('d-none');
                $('#formCalcularVencimento')[0].reset();
            });

        });
    </script>

@*}*@
}