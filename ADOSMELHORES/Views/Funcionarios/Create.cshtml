@model ADOSMELHORES.ViewModels.FuncionarioViewModel
@{
    ViewData["Title"] = "Novo Funcionário";
    var dataSistemaStr = Context.Request.Cookies["DataSistema"];
    DateTime dataReferencia = DateTime.TryParse(dataSistemaStr, out DateTime dt) ? dt : DateTime.Today;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="color: var(--azul-conhecimento); font-weight: 700; margin-bottom: 0;">Registar Funcionário</h2>
        <span class="text-muted">Preencha os dados base e os detalhes específicos do cargo</span>
    </div>
    <a asp-action="Index" class="btn btn-light border">
        <i class="fa-solid fa-arrow-left me-2"></i>Voltar
    </a>
</div>

<form asp-action="Create" method="post">
    <div class="row">
        <div class="col-lg-7">
            <div class="card card-ados mb-4">
                <div class="card-header card-ados-header">
                    <i class="fa-solid fa-user-gear me-2"></i>Dados Gerais (Comuns)
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Nome Completo</label>
                            <input type="text" asp-for="Nome" class="form-control" placeholder="Ex: João Silva" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Morada</label>
                            <input type="text" asp-for="Morada" class="form-control" placeholder="Rua, Número, Código Postal" />
                            <span asp-validation-for="Morada" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Contacto Telefónico</label>
                            <input type="tel" asp-for="Contacto" class="form-control" placeholder="9xxxxxxxx" />
                            <span asp-validation-for="Contacto" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Data Fim de Contrato</label>
                            <input type="date" asp-for="DataFimContrato" class="form-control" value="@dataReferencia.ToString("yyyy-MM-dd")"/>
                            <span asp-validation-for="DataFimContrato" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Data Registo Criminal</label>
                            <input type="date" asp-for="DataRegistoCriminal" class="form-control" value="@dataReferencia.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="DataRegistoCriminal" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Salário Base (€)</label>
                            <input type="number" step="0.01" asp-for="Salario" id="SalarioBase" class="form-control" placeholder="0.00" />
							<span asp-validation-for="Salario" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card card-ados mb-4 border-primary" style="border-width: 2px !important;">
                <div class="card-header bg-primary text-white">
                    <i class="fa-solid fa-briefcase me-2"></i>Cargo e Especialização
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label class="form-label fw-bold text-primary">Selecione o Tipo de Funcionário</label>
                        <select id="SelectTipoFuncionario" asp-for="TipoFuncionario" class="form-select form-select-lg border-primary">
                            <option value="">-- Selecione um cargo --</option>
                            <option value="Diretor">Diretor</option>
                            <option value="Secretaria">Secretaria</option>
                            <option value="Formador">Formador</option>
                            <option value="Coordenador">Coordenador</option>
                        </select>
                        <span asp-validation-for="TipoFuncionario" class="text-danger"></span>
                    </div>

                    <hr />

                    <div id="SecaoDiretor" class="secao-especifica d-none">
                        <h5 class="text-primary mb-3">Detalhes de Direção</h5>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="IsencaoHorario" asp-for="IsencaoHorario">
                            <label class="form-check-label" for="IsencaoHorario">Isenção de Horário</label>
                        </div>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="CarroEmpresa" asp-for="CarroEmpresa">
                            <label class="form-check-label" for="CarroEmpresa">Carro da Empresa</label>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Bónus Mensal (€)</label>
                            <input type="number" asp-for="BonusMensal" class="form-control" placeholder="0.00">
                            <span asp-validation-for="BonusMensal" class="text-danger"></span>
                        </div>
                    </div>

                    <div id="SecaoSecretaria" class="secao-especifica d-none">
                        <h5 class="text-primary mb-3">Detalhes de Secretaria</h5>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Reporta ao Diretor:</label>
                            <select asp-for="DiretorId" class="form-select" asp-items="@Model.ListaDiretores">
                            </select>
                            <span asp-validation-for="DiretorId" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Área de Atuação</label>
                            <input type="text" asp-for="Area" class="form-control" placeholder="Ex: Financeira, RH">
                            <span asp-validation-for="Area" class="text-danger"></span>
                        </div>
                    </div>

                    <div id="SecaoFormador" class="secao-especifica d-none">
                        <h5 class="text-primary mb-3">Detalhes de Formação</h5>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Reporta ao Diretor:</label>
                            <select asp-for="CoordenadorId" class="form-select" asp-items="@Model.ListaCoordenadores">
                            </select>
                            <span asp-validation-for="CoordenadorId" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Área que Leciona</label>
                            <input type="text" asp-for="AreaLecionada" class="form-control" placeholder="Ex: Programação, Design">
							<span asp-validation-for="AreaLecionada" class="text-danger"></span>    
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Disponibilidade</label>
                            <select asp-for="TipoDisponibilidade" class="form-select" asp-items="Html.GetEnumSelectList<ADOSMELHORES.Data.Empresa.Formador.Disponibilidade>()">
                                
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Valor Hora (€)</label>
                            <input type="number" asp-for="ValorHora" class="form-control" placeholder="0.00">
							<span asp-validation-for="ValorHora" class="text-danger"></span>
                        </div>
                    </div>

                    <div id="SecaoCoordenador" class="secao-especifica d-none">
                        <h5 class="text-primary mb-3">Detalhes de Coordenação</h5>
                        <div class="alert alert-info border-0" style="background-color: #e0f2fe; color: #0284c7;">
                            <h6 class="fw-bold mb-1">
                                <i class="fa-solid fa-circle-info me-2"></i>Gestão da Equipa
                            </h6>
                            <p class="mb-0 small">
                                Na página de detalhes deste coordenador poderá consultar a sua equipa e remover membros.
                                Para <strong>adicionar</strong> formadores a esta equipa, deve aceder ao perfil individual de cada Formador e associá-lo a este coordenador.
                            </p>
                        </div>
                    </div>

                    <div id="SecaoVazia" class="text-center py-4">
                        <i class="fa-solid fa-user-slash text-muted mb-2" style="font-size: 2rem; opacity: 0.3;"></i>
                        <p class="text-muted small">Selecione um cargo para ver campos específicos</p>
                    </div>

                </div>
                <div class="card-footer bg-light p-3">
                    <button type="submit" class="btn btn-ados w-100 py-2">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Guardar Funcionário
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {
            
            function atualizarVisibilidadeSecoes() {
                $('.secao-especifica').addClass('d-none');
                $('#SecaoVazia').addClass('d-none');

                var tipo = $('#SelectTipoFuncionario').val();

                if (!tipo || tipo === "") {
                    $('#SecaoVazia').removeClass('d-none');
                } else {
                    $('#Secao' + tipo).removeClass('d-none');
                    
                    if (tipo === "Formador") {
                        $('#SalarioBase').attr("disabled", true).val("");
                    } else {
                        $('#SalarioBase').attr("disabled", false);
                    }
                }
            }

            $('#SelectTipoFuncionario').change(atualizarVisibilidadeSecoes);

            atualizarVisibilidadeSecoes();
        });
    </script>
}