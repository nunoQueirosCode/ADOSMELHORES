@model ADOSMELHORES.ViewModels.FuncionarioViewModel
@{
    ViewData["Title"] = "Editar Funcionário";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="color: var(--azul-conhecimento); font-weight: 700; margin-bottom: 0;">Editar Funcionário</h2>
        <span class="text-muted">Atualize os dados e os detalhes específicos do cargo</span>
    </div>
    <a asp-action="Index" class="btn btn-light border">
        <i class="fa-solid fa-arrow-left me-2"></i>Voltar
    </a>
</div>

<form asp-action="Edit" method="post">
    
    <input type="hidden" asp-for="Id" />
    
    <input type="hidden" asp-for="TipoFuncionario" id="TipoFuncionarioHidden" />

    <div class="row">
        <div class="col-lg-7">
            <div class="card card-ados mb-4">
                <div class="card-header card-ados-header">
                    <i class="fa-solid fa-user-pen me-2"></i>Dados Gerais (Comuns)
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Nome Completo</label>
                            <input type="text" asp-for="Nome" class="form-control" value="@Model.Nome" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Morada</label>
                            <input type="text" asp-for="Morada" class="form-control" value="@Model.Morada" />
                            <span asp-validation-for="Morada" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Contacto Telefónico</label>
                            <input type="tel" asp-for="Contacto" class="form-control" value="@Model.Contacto" />
                            <span asp-validation-for="Contacto" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Data Fim de Contrato</label>
                            <input type="date" asp-for="DataFimContrato" class="form-control" value="@Model.DataFimContrato" />
                            <span asp-validation-for="DataFimContrato" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Data Registo Criminal</label>
                            <input type="date" asp-for="DataRegistoCriminal" class="form-control" value="@Model.DataRegistoCriminal" required />
                            <span asp-validation-for="DataRegistoCriminal" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Salário Base (€)</label>
                            <input type="number" step="0.01" asp-for="Salario" id="SalarioBase" class="form-control" value="@Model.Salario" />
                            <span asp-validation-for="Salario" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card card-ados mb-4 border-primary" style="border-width: 2px !important;">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span><i class="fa-solid fa-briefcase me-2"></i>Cargo e Especialização</span>
                    <span class="badge bg-light text-primary border border-light">@Model.TipoFuncionario</span>
                </div>
                <div class="card-body p-4">
                    
                    <div class="alert alert-secondary border-0 mb-4" style="background-color: #f8fafc;">
                        <i class="fa-solid fa-lock text-muted me-2"></i>
                        <small class="text-muted">O cargo do funcionário não pode ser alterado durante a edição.</small>
                    </div>

                    <hr />

                    <div id="SecaoDiretor" class="secao-especifica d-none">
                        <h5 class="text-primary mb-3">Detalhes de Direção</h5>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="IsencaoHorario" id="IsencaoHorario">
                            <label class="form-check-label" for="IsencaoHorario">Isenção de Horário</label>
                        </div>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="CarroEmpresa" id="CarroEmpresa">
                            <label class="form-check-label" for="CarroEmpresa">Carro da Empresa</label>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Bónus Mensal (€)</label>
                            <input type="number" step="0.01" asp-for="BonusMensal" class="form-control" value="@Model.BonusMensal">
                            <span asp-validation-for="BonusMensal" class="text-danger"></span>
                        </div>
                    </div>

                    <div id="SecaoSecretaria" class="secao-especifica d-none">
                        <h5 class="text-primary mb-3">Detalhes de Secretaria</h5>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Reporta ao Diretor:</label>
                            <select asp-for="DiretorId" class="form-select" asp-items="@Model.ListaDiretores">
                                <option value="">-- Selecione o Diretor --</option>
                            </select>
                            <span asp-validation-for="DiretorId" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Área de Atuação</label>
                            <input type="text" asp-for="Area" class="form-control" placeholder="Ex: Financeira, RH">
                            <span asp-validation-for="Area" class="text-danger"></span>
                        </div>
                    </div>

                    <div id="SecaoFormador" class="secao-especifica d-none">
                        <h5 class="text-primary mb-3">Detalhes de Formação</h5>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Área que Leciona</label>
                            <input type="text" asp-for="Area" class="form-control">
                            <span asp-validation-for="Area" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Disponibilidade</label>
                            <select asp-for="TipoDisponibilidade" class="form-select">
                                <option value="Laboral">Laboral</option>
                                <option value="PosLaboral" selected>Pós-Laboral</option>
                                <option value="Ambas">Ambas</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Valor Hora (€)</label>
                            <input type="number" step="0.01" asp-for="ValorHora" class="form-control" value="@Model.ValorHora">
                            <span asp-validation-for="ValorHora" class="text-danger"></span>
                        </div>
                    </div>

                    <div id="SecaoCoordenador" class="secao-especifica d-none">
                        <h5 class="text-primary mb-3">Detalhes de Coordenação</h5>
                        <div class="alert alert-info border-0" style="background-color: #e0f2fe; color: #0284c7;">
                            <h6 class="fw-bold mb-1">
                                <i class="fa-solid fa-circle-info me-2"></i>Gestão da Equipa
                            </h6>
                            <p class="mb-0 small">
                                Na página de detalhes deste coordenador poderá consultar a sua equipa e remover membros.
                                Para <strong>adicionar</strong> formadores a esta equipa, deve aceder ao perfil individual de cada Formador e associá-lo a este coordenador.
                            </p>
                        </div>
                    </div>

                </div>
                <div class="card-footer bg-light p-3">
                    <button type="submit" class="btn btn-ados w-100 py-2">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Guardar Alterações
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Obter o valor do tipo de funcionário a partir do campo escondido
            var tipo = $('#TipoFuncionarioHidden').val();

            // Esconder todas as secções por precaução
            $('.secao-especifica').addClass('d-none');

            // Se existir um tipo válido
            if (tipo) {
                // Mostrar a secção correta
                $('#Secao' + tipo).removeClass('d-none');
                
                // Aplicar a lógica do Salário Base (se for Formador, fica desativado)
                if (tipo === "Formador") {
                    $('#SalarioBase').attr("disabled", true);
                } else {
                    $('#SalarioBase').attr("disabled", false);
                }
            }
        });
    </script>
}